root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{cs,csproj,sln,props,targets}]
indent_style = space
indent_size = 4

[*.{json,yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.{sh,ps1}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
