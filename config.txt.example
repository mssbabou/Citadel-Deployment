# Citadel Deployment Server Configuration
# Written to /opt/citadel/config.txt by install-server.sh. Edit before starting the service.
#
# IMPORTANT: Change the token to a strong random value in production
# To generate a token:
# Linux: openssl rand -base64 32
# Windows PowerShell: Invoke-RestMethod -Uri "https://www.random.org/integers?num=32&min=1&max=256&col=1&base=16&format=plain" | ForEach-Object { $_ -join ',' }

token=your-very-secure-token-change-me-in-production

# HTTP port for the deployment server
# Common choices: 8080, 8090, 9090, 3000
port=9090
