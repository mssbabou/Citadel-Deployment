# Citadel Deployment Client Configuration
#
# IMPORTANT: This file contains sensitive credentials.
# - Never commit this file to version control
# - Use chmod 600 on Linux to restrict permissions
#
# To generate a strong token:
# Linux: openssl rand -base64 32
# Windows PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))

# Authentication token — must match [server] token in config.toml on the server
AUTH_TOKEN=your-very-secure-token-change-me

# Deployment server URL
DEPLOY_URL=https://deploy.example.com/deploy

# Profile name — must match a [profiles.<name>] entry in config.toml on the server
PROFILE=myapp

# Path to the file or directory to deploy (relative or absolute)
SOURCE=/path/to/your/build/output
